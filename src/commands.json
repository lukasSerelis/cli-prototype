{
  "welcome": "Test: show-controller with --bootstrap-logs flag\n\nTry:\n  juju show-controller myctrl\n  juju show-controller myctrl --bootstrap-logs",
  "variables": {},
  "commands": {
    "juju": {
      "description": "Test CLI",
      "commands": {
        "show-controller": {
          "description": "Show controller details",
          "options": {
            "bootstrap-logs": {
              "type": "boolean",
              "default": false,
              "description": "Show bootstrap logs"
            }
          },
          "commands": {
            "myctrl": {
              "description": "A test controller",
              "handler": [
                {
                  "component": "conditional",
                  "output": {
                    "if": "bootstrap-logs",
                    "then": [
                      {
                        "component": "text",
                        "output": "SUCCESS: You are seeing bootstrap logs.\n\n2026-03-06 09:50:10 INFO  bootstrap  starting bootstrap\n2026-03-06 09:50:11 INFO  bootstrap  validating credentials"
                      }
                    ],
                    "else": [
                      {
                        "component": "text",
                        "output": "SUCCESS: You are seeing controller details.\n\nmyctrl:\n  cloud: aws\n  region: eu-west-1\n  status: provisioning"
                      }
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
